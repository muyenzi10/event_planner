<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Professional wedding sound and lighting services to make your special day unforgettable. Expert sound systems, lighting design, and event coordination.">
    <meta name="keywords" content="wedding sound, wedding lighting, event sound, professional audio, wedding DJ, lighting design">
    <meta name="author" content="Wedding Planner">
    <title>Wedding Sound & Lighting | Professional Audio Visual</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous" />
    <!-- Font Awesome for icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
    <!-- AOS Animation Library -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    
    <!-- Your external CSS (kept exactly as you requested) -->
    <link rel="stylesheet" href="/allpack/layout/css/navbas.css">
    <link rel="stylesheet" href="/allpack/layout/css/footer.css">

    <!-- Additional inline styles -->
    <style>
        :root {
            --gold-primary: #D4AF37;
            --gold-secondary: #FFD700;
            --gold-light: #FFF8E7;
            --rose-gold: #B76E79;
            --dark-bg: #0a0a0a;
            --darker-bg: #050505;
            --dark-card: #1a1a1a;
        }

        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #fefefe;
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-secondary) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 1.2rem;
            cursor: pointer;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
            border: none;
        }

        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .back-to-top:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
        }

        /* ============ VIDEO HERO ============ */
        .video-hero {
            position: relative;
            width: 100%;
            height: 100vh;
            min-height: 600px;
            overflow: hidden;
            background: #000;
        }

        .video-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                135deg,
                rgba(183, 110, 121, 0.2) 0%,
                rgba(32, 32, 32, 0.55) 40%,
                rgba(32, 32, 32, 0.65) 50%,
                rgba(32, 32, 32, 0.55) 60%,
                rgba(212, 175, 55, 0.2) 100%
            );
            z-index: 2;
        }

        .video-hero video {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: translate(-50%, -50%);
            z-index: 1;
        }

        /* ============ SOUND BADGE ABOVE HERO – THREE ICONS LEFT, CENTER, RIGHT ============ */
        .sound-badge-above {
            position: absolute;
            top: 15%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 5;
            width: 380px;          /* wide enough for three icons */
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
            border-radius: 60px;
            padding: 0 30px;
            border: 1px solid rgba(212, 175, 55, 0.3);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }

        .sound-icon {
            font-size: 3rem;
            filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.8));
            display: flex;
            align-items: center;
            justify-content: center;
            width: 70px;
            height: 70px;
        }

        .sound-icon i {
            animation: iconFloat 4s ease-in-out infinite;
        }

        /* individual animation delays for variety */
        .sound-icon.left i {
            animation-delay: 0s;
            color: var(--gold-primary);
        }
        .sound-icon.center i {
            animation-delay: 0.5s;
            color: var(--gold-secondary);
        }
        .sound-icon.right i {
            animation-delay: 1s;
            color: var(--rose-gold);
        }

        .sound-connector {
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            height: 50px;
            background: linear-gradient(to bottom, 
                rgba(212, 175, 55, 0.8) 0%, 
                rgba(212, 175, 55, 0.3) 70%, 
                transparent 100%);
            animation: connectorFade 4s ease-in-out infinite;
        }

        @keyframes iconFloat {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-10px) scale(1.1); }
        }

        @keyframes connectorFade {
            0%, 100% { opacity: 0.5; height: 50px; }
            50% { opacity: 1; height: 70px; }
        }

        /* ============ HERO CONTENT ============ */
        .hero-content {
            position: relative;
            z-index: 4;
            color: #fff;
            height: 100vh;
            min-height: 600px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 20px;
        }

        .hero-content .container {
            max-width: 1200px;
            animation: fadeInUp 1s ease-out 0.3s forwards;
            opacity: 0;
            padding-top: 80px;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 5vw, 4.5rem);
            font-weight: 700;
            margin-bottom: 1.5rem;
            text-shadow: 3px 3px 15px rgba(0, 0, 0, 0.5);
            line-height: 1.1;
            position: relative;
        }

        .hero-title::before {
            content: '';
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background: linear-gradient(to right, transparent, var(--gold-primary), transparent);
        }

        .highlight-word {
            font-family: 'Dancing Script', cursive;
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-secondary) 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-block;
            position: relative;
        }

        .hero-subtitle {
            font-size: clamp(1.1rem, 2vw, 1.8rem);
            font-weight: 300;
            margin-bottom: 2.5rem;
            opacity: 0.95;
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.4;
        }

        /* ============ BUTTONS ============ */
        .btn-gold-gradient {
            background: linear-gradient(135deg, var(--gold-primary) 0%, var(--gold-secondary) 100%);
            border: none;
            color: #000;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
            text-decoration: none;
            display: inline-block;
        }

        .btn-gold-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(212, 175, 55, 0.4);
            color: #000;
        }

        .btn-outline-light {
            background: transparent;
            border: 2px solid rgba(255, 255, 255, 0.3);
            color: #fff;
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-outline-light:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--gold-primary);
            color: #fff;
        }

        /* ============ SCROLL INDICATOR ============ */
        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 5;
            cursor: pointer;
        }

        .scroll-indicator i {
            color: var(--gold-primary);
            font-size: 2rem;
            animation: bounce 2s infinite;
        }

        /* ============ ANIMATIONS ============ */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }

        /* ============ ORIGINAL SOUND PAGE STYLES (preserved) ============ */
        body {
            font-family: 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            transition: background-color 0.3s, color 0.3s;
        }
        .dark-mode {
            background-color: #1a1a1a;
            color: #f0f0f0;
        }
        .display-4 {
            font-weight: bold;
            color: #fdfeff;
        }
        .lead {
            color: #7f8c8d;
        }
        .custom-image {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border-radius: 15px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }
        .custom-image:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
        }
        .custom-card {
            width: 100%;
            height: auto;
            border: none;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
            border-radius: 10px;
            margin: 10px;
            overflow: hidden;
        }
        .custom-card img {
            height: 300px;
            object-fit: cover;
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
        }
        .custom-card .card-body {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .custom-card .card-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .custom-card .card-text {
            color: #7f8c8d;
            font-size: 1rem;
            line-height: 1.5;
            margin-bottom: 15px;
        }
        .custom-card:hover {
            transform: scale(1.05);
        }
        .dark-mode-toggle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #3498db;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            cursor: pointer;
            z-index: 1000;
        }
        .parallax {
            background-image: url('/allpack/sound/sounddata/sound1.jpg');
            background-attachment: fixed;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        }
        .carousel-control-prev,
        .carousel-control-next {
            width: 50px;
            height: 50px;
            background-color: rgb(168, 23, 23);
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.8;
            transition: opacity 0.3s ease;
        }
        .carousel-control-prev:hover,
        .carousel-control-next:hover {
            opacity: 1;
            background-color: rgba(172, 67, 67, 0.9);
        }
        .carousel-control-prev {
            left: -25px;
        }
        .carousel-control-next {
            right: -25px;
        }
        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            filter: invert(1);
            width: 30px;
            height: 30px;
        }
        .testimonials {
            background-color: #f8f9fa;
            padding: 50px 0;
        }
        .dark-mode .testimonials {
            background-color: #1a1a1a;
        }
        .testimonial-card {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
            transition: background-color 0.3s, color 0.3s;
        }
        .dark-mode .testimonial-card {
            background-color: #2c3e50;
            color: #f0f0f0;
        }
        .testimonial-card h5 {
            font-weight: bold;
            margin-bottom: 10px;
        }
        .testimonial-card p {
            color: #7f8c8d;
            font-style: italic;
        }
        .dark-mode .testimonial-card p {
            color: #bdc3c7;
        }
        @media (max-width: 768px) {
            .custom-image {
                height: 200px;
            }
            .custom-card {
                width: 100%;
                margin: 10px 0;
            }
            .carousel-control-prev,
            .carousel-control-next {
                display: none;
            }
            .sound-badge-above {
                width: 300px;
                height: 80px;
                padding: 0 20px;
            }
            .sound-icon {
                font-size: 2.2rem;
                width: 50px;
                height: 50px;
            }
        }
    </style>
</head>
<body>
    <%- include('../layout/navbar') %>

    <!-- Dark Mode Toggle -->
    <button class="dark-mode-toggle" onclick="toggleDarkMode()">
        <i class="fas fa-moon"></i> Dark Mode
    </button>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
        <i class="fas fa-chevron-up"></i>
    </button>

    <!-- VIDEO HERO SECTION (SOUND VERSION) -->
    <section class="video-hero">
        <!-- BADGE WITH THREE ICONS: left, center, right -->
        <div class="sound-badge-above">
            <div class="sound-icon left"><i class="fas fa-microphone"></i></div>
            <div class="sound-icon center"><i class="fas fa-music"></i></div>
            <div class="sound-icon right"><i class="fas fa-volume-up"></i></div>
            <div class="sound-connector"></div>
        </div>

        <video 
            autoplay 
            loop 
            muted 
            playsinline
            disablePictureInPicture
            controlsList="nodownload nofullscreen noremoteplayback nopictureinpicture"
            poster="/allpack/sound/sounddata/sound1.jpg">
            <source src="/allpack/sound/sounddata/sound-hero.mp4" type="video/mp4">
        </video>

        <div class="hero-content">
            <div class="container">
                <h1 class="hero-title">
                    Professional <span class="highlight-word">Sound & Lighting</span> for Your Wedding
                </h1>
                
                <p class="hero-subtitle">
                    From crystal-clear audio to breathtaking lighting design – we create the perfect ambiance for your celebration. Trust our experts to make every moment unforgettable.
                </p>
                
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/booking" class="btn btn-gold-gradient">
                        <i class="fas fa-headphones me-2"></i>Explore Packages
                    </a>
                    <a href="#contact" class="btn btn-outline-light">
                        <i class="fas fa-envelope me-2"></i>Get a Quote
                    </a>
                </div>
            </div>
        </div>

        <div class="scroll-indicator">
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>

    <!-- (Optional) demonstration row – can be removed if not needed, but kept for clarity -->
    <section class="container my-5 py-4" style="background: #f9f9f9; border-radius: 20px;">
        <h2 class="text-center mb-4" style="font-family: 'Playfair Display';">Icons at different positions (flex example)</h2>
        <div class="row align-items-center">
            <div class="col-md-4 text-start">
                <i class="fas fa-microphone fa-3x text-primary"></i>
                <p class="mt-2">Left aligned</p>
            </div>
            <div class="col-md-4 text-center">
                <i class="fas fa-music fa-3x text-success"></i>
                <p class="mt-2">Center aligned</p>
            </div>
            <div class="col-md-4 text-end">
                <i class="fas fa-volume-up fa-3x text-warning"></i>
                <p class="mt-2">Right aligned</p>
            </div>
        </div>
    </section>

    <!-- ========== ORIGINAL SOUND PAGE CONTENT (preserved) ========== -->
    <section class="container my-5">
        <div class="row">
            <div class="col-md-12 text-center">
                <h1 class="display-5" data-aos="fade-up">Wedding Sound & Lighting Services</h1>
                <p class="lead" data-aos="fade-up" data-aos-delay="100">Make your special day unforgettable with our professional audio and lighting solutions.</p>
            </div>
        </div>

        <!-- Sound Systems -->
        <div class="row mt-5">
            <div class="col-md-6" data-aos="fade-right">
                <img src="/allpack/sound/sounddata/sound1.jpg" alt="Sound System" class="img-fluid rounded custom-image">
            </div>
            <div class="col-md-6" data-aos="fade-left" data-aos-delay="100">
                <h2>Sound Systems</h2>
                <p>Our state-of-the-art sound systems ensure crystal-clear audio for every moment of your wedding. From the ceremony to the reception, we provide tailored solutions to meet your needs.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check-circle text-primary"></i> High-quality speakers and microphones</li>
                    <li><i class="fas fa-check-circle text-primary"></i> Wireless and wired setups</li>
                    <li><i class="fas fa-check-circle text-primary"></i> Expert sound technicians</li>
                </ul>
            </div>
        </div>

        <!-- Lighting Design -->
        <div class="row mt-5">
            <div class="col-md-6 order-md-2" data-aos="fade-left">
                <img src="/allpack/sound/sounddata/sound2.jpg" alt="Lighting Design" class="img-fluid rounded custom-image">
            </div>
            <div class="col-md-6 order-md-1" data-aos="fade-right" data-aos-delay="100">
                <h2>Lighting Design</h2>
                <p>Create the perfect ambiance for your wedding with our professional lighting services. From elegant uplighting to dynamic stage lighting, we bring your vision to life.</p>
                <ul class="list-unstyled">
                    <li><i class="fas fa-check-circle text-primary"></i> Custom lighting designs</li>
                    <li><i class="fas fa-check-circle text-primary"></i> LED and intelligent lighting</li>
                    <li><i class="fas fa-check-circle text-primary"></i> Energy-efficient solutions</li>
                </ul>
            </div>
        </div>

        <!-- Card-Style Gallery Slider -->
        <div class="row mt-5">
            <div class="col-md-12 text-center">
                <h2 data-aos="fade-up">Our Work in Action</h2>
                <p class="lead" data-aos="fade-up" data-aos-delay="100">Check out some of our recent wedding projects.</p>
            </div>
            <div class="col-md-12 card-slider" data-aos="fade-up">
                <div id="cardCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <!-- First Slide -->
                        <div class="carousel-item active">
                            <div class="d-flex justify-content-center">
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound3.jpg">
                                        <img src="/allpack/sound/sounddata/sound3.jpg" class="card-img-top" alt="Gallery Image 1">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Wedding Sound Setup</h5>
                                        <p class="card-text">Perfect audio for your special day.</p>
                                    </div>
                                </div>
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound11.jpg">
                                        <img src="/allpack/sound/sounddata/sound11.jpg" class="card-img-top" alt="Gallery Image 2">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Event Lighting Design</h5>
                                        <p class="card-text">Creating the perfect ambiance.</p>
                                    </div>
                                </div>
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound5.jpg">
                                        <img src="/allpack/sound/sounddata/sound5.jpg" class="card-img-top" alt="Gallery Image 3">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Wedding Reception Setup</h5>
                                        <p class="card-text">Professional sound and lighting for wedding receptions.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Second Slide -->
                        <div class="carousel-item">
                            <div class="d-flex justify-content-center">
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound6.jpg">
                                        <img src="/allpack/sound/sounddata/sound6.jpg" class="card-img-top" alt="Gallery Image 4">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Outdoor Wedding Setup</h5>
                                        <p class="card-text">Perfect sound and lighting for outdoor weddings.</p>
                                    </div>
                                </div>
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound7.jpg">
                                        <img src="/allpack/sound/sounddata/sound7.jpg" class="card-img-top" alt="Gallery Image 5">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Wedding Stage Lighting</h5>
                                        <p class="card-text">Dynamic lighting for wedding stages.</p>
                                    </div>
                                </div>
                                <div class="card custom-card">
                                    <a href="/allpack/sound/sounddata/sound8.jpg">
                                        <img src="/allpack/sound/sounddata/sound8.jpg" class="card-img-top" alt="Gallery Image 6">
                                    </a>
                                    <div class="card-body">
                                        <h5 class="card-title">Wedding Ceremony Setup</h5>
                                        <p class="card-text">Professional sound and lighting for wedding ceremonies.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#cardCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#cardCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Why Choose Us Section -->
        <div class="row mt-5">
            <div class="col-md-12 text-center" data-aos="fade-up">
                <h2>Why Choose Our Sound & Lighting?</h2>
