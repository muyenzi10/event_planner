<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Professional wedding sound and lighting services to make your special day unforgettable. Expert sound systems, lighting design, and event coordination.">
    <meta name="keywords" content="wedding sound, wedding lighting, event sound, professional audio, wedding DJ, lighting design">
    <meta name="author" content="Wedding Planner">
    <title>Wedding Sound & Lighting | Professional Audio Visual</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
    <!-- AOS Animation -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    
    <!-- External CSS (navbar & footer) -->
    <link rel="stylesheet" href="/allpack/layout/css/navbas.css">
    <link rel="stylesheet" href="/allpack/layout/css/footer.css">

    <style>
        :root {
            --gold-primary: #D4AF37;
            --gold-secondary: #FFD700;
            --gold-light: #FFF8E7;
            --rose-gold: #B76E79;
            --dark-bg: #0a0a0a;
            --darker-bg: #050505;
            --dark-card: #1a1a1a;
            --text-muted: #6c757d;
        }

        html { scroll-behavior: smooth; }
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #fefefe;
            overflow-x: hidden;
            line-height: 1.6;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Dark mode styles */
        body.dark-mode {
            background-color: var(--dark-bg);
            color: #f0f0f0;
        }
        body.dark-mode .text-muted { color: #adb5bd !important; }
        body.dark-mode .bg-white { background-color: var(--dark-card) !important; }
        body.dark-mode .portfolio-card .bg-white { background-color: var(--dark-card) !important; }
        body.dark-mode .portfolio-card small { color: #adb5bd !important; }
        body.dark-mode .bg-gold-light { background: #2a2a2a; }
        body.dark-mode .btn-outline-dark { border-color: #f0f0f0; color: #f0f0f0; }
        body.dark-mode .btn-outline-dark:hover { background: #f0f0f0; color: #000; }

        /* Back to Top Button */
        .back-to-top {
            position: fixed; bottom: 30px; right: 30px;
            width: 50px; height: 50px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #000; font-size: 1.2rem; cursor: pointer;
            z-index: 1000; opacity: 0; visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
            border: none;
        }
        .back-to-top.visible { opacity: 1; visibility: visible; }
        .back-to-top:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4); }

        /* Dark Mode Toggle */
        .dark-mode-toggle {
            position: fixed; bottom: 20px; right: 20px;
            background: #3498db; color: white; border: none;
            padding: 10px 20px; border-radius: 50px; cursor: pointer;
            z-index: 1000; font-weight: 500; transition: 0.3s;
        }
        .dark-mode-toggle:hover { background: #2980b9; }

        /* ============ VIDEO HERO ============ */
        .video-hero {
            position: relative; width: 100%; height: 100vh; min-height: 600px;
            overflow: hidden; background: #000;
        }
        .video-hero::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(183,110,121,0.2) 0%, rgba(32,32,32,0.55) 40%, rgba(32,32,32,0.65) 50%, rgba(32,32,32,0.55) 60%, rgba(212,175,55,0.2) 100%);
            z-index: 2;
        }
        .video-hero video {
            position: absolute; top: 50%; left: 50%; width: 100%; height: 100%;
            object-fit: cover; transform: translate(-50%, -50%); z-index: 1;
        }

        /* Sound Badge Above Hero */
        .sound-badge-above {
            position: absolute; top: 15%; left: 50%; transform: translateX(-50%);
            z-index: 5; width: 380px; height: 100px;
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
            border-radius: 60px; padding: 0 30px;
            border: 1px solid rgba(212,175,55,0.3); box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }
        .sound-icon {
            font-size: 3rem; filter: drop-shadow(0 0 20px rgba(212,175,55,0.8));
            display: flex; align-items: center; justify-content: center;
            width: 70px; height: 70px;
        }
        .sound-icon i { animation: iconFloat 4s ease-in-out infinite; }
        .sound-icon.left i { animation-delay: 0s; color: var(--gold-primary); }
        .sound-icon.center i { animation-delay: 0.5s; color: var(--gold-secondary); }
        .sound-icon.right i { animation-delay: 1s; color: var(--rose-gold); }

        .sound-connector {
            position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
            width: 2px; height: 50px;
            background: linear-gradient(to bottom, rgba(212,175,55,0.8) 0%, rgba(212,175,55,0.3) 70%, transparent 100%);
            animation: connectorFade 4s ease-in-out infinite;
        }

        @keyframes iconFloat { 0%,100%{ transform:translateY(0) scale(1); } 50%{ transform:translateY(-10px) scale(1.1); } }
        @keyframes connectorFade { 0%,100%{ opacity:0.5; height:50px; } 50%{ opacity:1; height:70px; } }

        /* Hero Content */
        .hero-content {
            position: relative; z-index: 4; color: #fff; height: 100vh; min-height: 600px;
            display: flex; align-items: center; justify-content: center; text-align: center;
            padding: 0 20px;
        }
        .hero-content .container {
            max-width: 1200px; animation: fadeInUp 1s ease-out 0.3s forwards; opacity: 0; padding-top: 80px;
        }
        .hero-title {
            font-family: 'Playfair Display', serif; font-size: clamp(2.5rem,5vw,4.5rem);
            font-weight: 700; margin-bottom: 1.5rem; text-shadow: 3px 3px 15px rgba(0,0,0,0.5);
            line-height: 1.1; position: relative;
        }
        .hero-title::before {
            content: ''; position: absolute; top: -30px; left: 50%; transform: translateX(-50%);
            width: 80px; height: 3px; background: linear-gradient(to right, transparent, var(--gold-primary), transparent);
        }
        .highlight-word {
            font-family: 'Dancing Script', cursive;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
            -webkit-background-clip: text; background-clip: text; color: transparent;
            display: inline-block;
        }
        .hero-subtitle {
            font-size: clamp(1.1rem,2vw,1.8rem); font-weight: 300; margin-bottom: 2.5rem;
            opacity: 0.95; max-width: 900px; margin-left: auto; margin-right: auto; line-height: 1.4;
        }

        /* Buttons */
        .btn-gold-gradient {
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
            border: none; color: #000; font-weight: 600; padding: 1rem 2.5rem;
            border-radius: 50px; transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(212,175,55,0.3); text-decoration: none; display: inline-block;
        }
        .btn-gold-gradient:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(212,175,55,0.4); color: #000; }

        .btn-outline-light {
            background: transparent; border: 2px solid rgba(255,255,255,0.3); color: #fff;
            padding: 0.8rem 2rem; border-radius: 50px; transition: all 0.3s ease; text-decoration: none;
            display: inline-block;
        }
        .btn-outline-light:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-primary); color: #fff; }

        .btn-outline-gold {
            border: 2px solid var(--gold-primary); color: var(--gold-primary); background: transparent;
            transition: all 0.3s; border-radius: 50px; padding: 0.6rem 1.5rem;
        }
        .btn-outline-gold:hover { background: var(--gold-primary); color: #000; }

        .btn-outline-dark {
            border: 2px solid #000; color: #000; background: transparent; transition: 0.3s;
        }
        .btn-outline-dark:hover { background: #000; color: #fff; }

        /* Scroll Indicator */
        .scroll-indicator {
            position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
            z-index: 5; cursor: pointer;
        }
        .scroll-indicator i { color: var(--gold-primary); font-size: 2rem; animation: bounce 2s infinite; }

        @keyframes fadeInUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        @keyframes bounce { 0%,20%,50%,80%,100%{ transform:translateY(0); } 40%{ transform:translateY(-10px); } 60%{ transform:translateY(-5px); } }

        /* ============ REDESIGNED SECTION STYLES ============ */
        .text-gold { color: var(--gold-primary) !important; }
        .bg-gold-subtle { background: rgba(212,175,55,0.12); }
        .bg-gold-light { background: linear-gradient(145deg, #fff9e6, #fff0d4); }
        .bg-gold { background: var(--gold-primary); }
        .text-gradient-gold {
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }
        .experience-badge {
            background: var(--gold-primary); color: #1a1a1a; line-height: 1.2;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2); font-weight: bold;
        }
        .portfolio-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: white; border: none;
        }
        .portfolio-card:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
        }
        .border-gold-soft { border-color: rgba(212,175,55,0.2) !important; }

        /* Card image sizing */
        .portfolio-card img {
            height: 200px;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .portfolio-card:hover img {
            transform: scale(1.05);
        }
        .portfolio-card .p-3 {
            padding: 1rem;
        }
        .portfolio-card h6 {
            font-size: 1rem;
            margin-bottom: 0.25rem;
        }
        .portfolio-card small {
            font-size: 0.85rem;
        }

        /* Larger images on bigger screens */
        @media (min-width: 768px) {
            .portfolio-card img {
                height: 220px;
            }
        }
        @media (min-width: 992px) {
            .portfolio-card img {
                height: 250px;
            }
        }

        /* Dark mode card background */
        body.dark-mode .portfolio-card .bg-white {
            background-color: var(--dark-card);
        }
        body.dark-mode .portfolio-card small {
            color: #adb5bd;
        }

        /* Carousel controls styling (shared) */
        .carousel-control-prev,
        .carousel-control-next {
            width: auto;
            background: none !important;
            opacity: 1;
        }
        .carousel-control-prev span,
        .carousel-control-next span {
            width: 2.8rem;
            height: 2.8rem;
            background: var(--gold-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: transform 0.2s, background-color 0.2s;
        }
        .carousel-control-prev span i,
        .carousel-control-next span i {
            color: #000;
            font-size: 1.2rem;
        }
        .carousel-control-prev:hover span,
        .carousel-control-next:hover span {
            transform: scale(1.1);
            background: var(--gold-secondary);
        }

        /* Desktop carousel: make controls a bit larger */
        @media (min-width: 768px) {
            .carousel-control-prev span,
            .carousel-control-next span {
                width: 3.2rem;
                height: 3.2rem;
            }
            .carousel-control-prev span i,
            .carousel-control-next span i {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../layout/navbar') %>

    <!-- Dark Mode Toggle -->
    <button class="dark-mode-toggle" onclick="toggleDarkMode()">
        <i class="fas fa-moon"></i> Dark Mode
    </button>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
        <i class="fas fa-chevron-up"></i>
    </button>

    <!-- VIDEO HERO SECTION -->
    <section class="video-hero">
        <div class="sound-badge-above">
            <div class="sound-icon left"><i class="fas fa-microphone"></i></div>
            <div class="sound-icon center"><i class="fas fa-music"></i></div>
            <div class="sound-icon right"><i class="fas fa-volume-up"></i></div>
            <div class="sound-connector"></div>
        </div>

        <video autoplay loop muted playsinline disablePictureInPicture
               controlsList="nodownload nofullscreen noremoteplayback nopictureinpicture"
               poster="/allpack/sound/sounddata/sound1.jpg">
            <source src="/allpack/sound/sounddata/sound-hero.mp4" type="video/mp4">
        </video>

        <div class="hero-content">
            <div class="container">
                <h1 class="hero-title">
                    Professional <span class="highlight-word">Sound & Lighting</span> for Your Wedding
                </h1>
                <p class="hero-subtitle">
                    From crystal-clear audio to breathtaking lighting design – we create the perfect ambiance for your celebration. Trust our experts to make every moment unforgettable.
                </p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/booking" class="btn btn-gold-gradient">
                        <i class="fas fa-headphones me-2"></i>Explore Packages
                    </a>
                </div>
            </div>
        </div>

        <div class="scroll-indicator">
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>

    <!-- MAIN SERVICES SECTION -->
    <section id="main-services" class="container my-5 py-4">
        <!-- Section Header -->
        <div class="row mb-5 text-center" data-aos="fade-up">
            <div class="col-lg-8 mx-auto">
                <span class="badge bg-gold-subtle text-gold px-4 py-2 rounded-pill mb-3">
                    <i class="fas fa-waveform me-2"></i>Wedding Audio Visual Excellence
                </span>
                <h2 class="display-5 fw-bold mb-3">Sound & Lighting <span class="text-gradient-gold">Perfected</span></h2>
                <p class="lead text-muted">We blend cutting-edge technology with artistic flair to create an immersive atmosphere your guests will never forget.</p>
            </div>
        </div>

        <!-- Sound Systems Deep Dive -->
        <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
            <div class="col-lg-6" data-aos="fade-right">
                <div class="position-relative">
                    <img src="/allpack/sound/sounddata/sound1.jpg" alt="Professional sound system setup" class="img-fluid rounded-4 shadow-lg">
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-left" data-aos-delay="100">
                <span class="badge bg-gold-subtle text-gold px-3 py-2 rounded-pill mb-3">SOUND SYSTEMS</span>
                <h3 class="fw-bold mb-3">Crystal‑Clear Audio for Every Moment</h3>
                <p class="text-muted mb-4">From the softest whisper of your vows to the energy of your first dance—our sound systems deliver pristine, natural audio. We tailor the setup to your venue, ensuring perfect coverage without feedback or distortion.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> High‑definition line arrays & subwoofers</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Wireless handheld & lapel microphones</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Dedicated sound engineer on site</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Seamless integration with live musicians or DJ</li>
                </ul>
                <a href="/booking" class="btn btn-outline-gold rounded-pill px-4 mt-3">Explore sound packages <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
        </div>

        <!-- Lighting Design Deep Dive -->
        <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
            <div class="col-lg-6 order-lg-2" data-aos="fade-left">
                <img src="/allpack/sound/sounddata/sound2.jpg" alt="Elegant wedding lighting" class="img-fluid rounded-4 shadow-lg">
            </div>
            <div class="col-lg-6 order-lg-1" data-aos="fade-right" data-aos-delay="100">
                <span class="badge bg-gold-subtle text-gold px-3 py-2 rounded-pill mb-3">LIGHTING DESIGN</span>
                <h3 class="fw-bold mb-3">Set the Mood with Light</h3>
                <p class="text-muted mb-4">Lighting transforms a space—whether you desire a romantic, candlelit glow or a vibrant, colourful reception. Our designers create custom lighting plots that enhance your decor and photograph beautifully.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Uplighting in your wedding colours</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Monogram / gobo projection (your names or logo)</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Dynamic dance floor effects: moving heads, strobes</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-gold me-2"></i> Fairy light backdrops & soft ambient options</li>
                </ul>
                <a href="/booking" class="btn btn-outline-gold rounded-pill px-4 mt-3">View lighting options <i class="fas fa-arrow-right ms-2"></i></a>
            </div>
        </div>

        <!-- Gallery / Portfolio – Mobile: 1 pic/slide carousel, Desktop: 3 pics/slide carousel -->
        <div class="row mt-5 pt-4" data-aos="fade-up">
            <div class="col-12 text-center mb-4">
                <h3 class="fw-bold">Recent Weddings We've Lit & Soundtracked</h3>
                <p class="text-muted">Real moments from real celebrations.</p>
            </div>
            <div class="col-12">
                <!-- MOBILE CAROUSEL (1 per slide) - visible only on small screens -->
                <div class="d-block d-md-none">
                    <div id="mobileCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="false">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound3.jpg" class="img-fluid w-100" alt="Wedding sound setup">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">Outdoor ceremony PA</h6>
                                        <small class="text-muted">Clear sound for hillside vows</small>
                                    </div>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound11.jpg" class="img-fluid w-100" alt="Wedding lighting design">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">Elegant uplighting</h6>
                                        <small class="text-muted">Reception in gold & ivory</small>
                                    </div>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound5.jpg" class="img-fluid w-100" alt="Wedding reception lighting">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">Dance floor energy</h6>
                                        <small class="text-muted">Moving heads & gobo</small>
                                    </div>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound6.jpg" class="img-fluid w-100" alt="Outdoor wedding sound">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">Intimate marquee setup</h6>
                                        <small class="text-muted">Speeches & background music</small>
                                    </div>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound7.jpg" class="img-fluid w-100" alt="Ceremony lighting">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">Ceremony lighting</h6>
                                        <small class="text-muted">Soft wash on aisle</small>
                                    </div>
                                </div>
                            </div>
                            <div class="carousel-item">
                                <div class="portfolio-card rounded-4 overflow-hidden shadow-sm">
                                    <img src="/allpack/sound/sounddata/sound8.jpg" class="img-fluid w-100" alt="First dance spotlight">
                                    <div class="p-3 bg-white">
                                        <h6 class="fw-bold mb-1">First dance spotlight</h6>
                                        <small class="text-muted">Follow spot & atmosphere</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#mobileCarousel" data-bs-slide="prev">
                            <span><i class="fas fa-chevron-left"></i></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#mobileCarousel" data-bs-slide="next">
                            <span><i class="fas fa-chevron-right"></i></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>

                <!-- DESKTOP CAROUSEL (3 per slide) - visible on medium and up -->
                <div class="d-none d-md-block">
                    <div id="desktopCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="false">
                        <div class="carousel-inner">
                            <!-- Slide 1: images 1-3 -->
                            <div class="carousel-item active">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="portfolio-card rounded-4 overflow-hidden shadow-sm h-100">
                                            <img src="/allpack/sound/sounddata/sound3.jpg" class="img-fluid w-100" alt="Wedding sound setup">
                                            <div class="p-3 bg-white">
                                                <h6 class="fw-bold mb-1">Outdoor ceremony PA</h6>
                                                <small class="text-muted">Clear sound for hillside vows</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="portfolio-card rounded-4 overflow-hidden shadow-sm h-100">
                                            <img src="/allpack/sound/sounddata/sound11.jpg" class="img-fluid w-100" alt="Wedding lighting design">
                                            <div class="p-3 bg-white">
                                                <h6 class="fw-bold mb-1">Elegant uplighting</h6>
                                                <small class="text-muted">Reception in gold & ivory</small>
                                            </div>
                                        </div>
                                    </div>
