<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unique Invitation Cards</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&family=Quicksand:wght@300;400;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>

    <!-- Your existing CSS files (navbas, footer) - keep paths as is -->
    <link rel="stylesheet" href="/allpack/layout/css/navbas.css">
    <link rel="stylesheet" href="/allpack/layout/css/footer.css">

    <style>
        :root {
            --primary-lavender: #9b8bcf;
            --primary-blush: #f7cac9;
            --gold-soft: #e6c8a0;
            --deep-rose: #b76e79;
            --dark-lavender: #6b5b95;
            --bg-light: #fff9f9;
        }

        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Quicksand', sans-serif;
            background-color: var(--bg-light);
            overflow-x: hidden;
            line-height: 1.6;
            color: #4a4a4a;
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary-lavender) 0%, var(--deep-rose) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(107, 91, 149, 0.3);
            border: none;
        }

        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .back-to-top:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(107, 91, 149, 0.4);
        }

        /* ============ VIDEO HERO ============ */
        .video-hero {
            position: relative;
            width: 100%;
            height: 100vh;
            min-height: 650px;
            overflow: hidden;
            background: #1a1a2e;
        }

        .video-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(155, 139, 207, 0.3) 0%, rgba(26, 26, 46, 0.7) 50%, rgba(183, 110, 121, 0.3) 100%);
            z-index: 2;
        }

        .video-hero video {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: translate(-50%, -50%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 5;
            color: #fff;
            height: 100vh;
            min-height: 650px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 20px;
        }

        .hero-content .container {
            max-width: 900px;
            animation: fadeInUp 1s ease-out forwards;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 5rem);
            font-weight: 700;
            margin-bottom: 1.5rem;
            text-shadow: 3px 3px 20px rgba(0,0,0,0.5);
            line-height: 1.1;
        }

        .hero-title .typed-text {
            font-family: 'Dancing Script', cursive;
            background: linear-gradient(135deg, var(--primary-blush), var(--gold-soft));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            display: inline-block;
        }

        .hero-subtitle {
            font-size: clamp(1.2rem, 2.5vw, 1.8rem);
            font-weight: 300;
            margin-bottom: 2rem;
            opacity: 0.95;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-gradient {
            background: linear-gradient(135deg, var(--primary-lavender) 0%, var(--deep-rose) 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(107, 91, 149, 0.4);
            text-decoration: none;
            display: inline-block;
            font-size: 1.2rem;
        }

        .btn-gradient:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(107, 91, 149, 0.6);
            color: white;
        }

        .btn-outline-unique {
            background: transparent;
            border: 2px solid var(--primary-blush);
            color: white;
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-outline-unique:hover {
            background: var(--primary-blush);
            color: #4a4a4a;
            border-color: var(--primary-blush);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 5;
            cursor: pointer;
            animation: bounce 2s infinite;
        }

        .scroll-indicator i {
            color: white;
            font-size: 2rem;
            text-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        /* ============ GALLERY SECTION (enhanced) ============ */
        .gallery-section {
            padding: 80px 0;
            background: var(--bg-light);
        }

        .gallery-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            text-align: center;
            margin-bottom: 1rem;
            color: var(--dark-lavender);
        }

        .section-subtitle {
            text-align: center;
            color: #777;
            font-size: 1.2rem;
            margin-bottom: 3rem;
        }

        /* Filter Buttons */
        .filter-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin-bottom: 40px;
        }

        .filter-btn {
            padding: 8px 25px;
            border: 2px solid var(--primary-lavender);
            background: transparent;
            color: var(--dark-lavender);
            border-radius: 30px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
        }

        .filter-btn.active,
        .filter-btn:hover {
            background: var(--primary-lavender);
            color: white;
            border-color: var(--deep-rose);
        }

        /* Gallery Grid */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            padding: 0 20px;
        }

        .gallery-item {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.5s;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .gallery-item:hover {
            transform: translateY(-15px) rotateX(2deg) rotateY(2deg);
            box-shadow: 0 30px 45px rgba(107, 91, 149, 0.2);
        }

        .gallery-item img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            transition: transform 0.8s;
            display: block;
            cursor: pointer;
        }

        .gallery-item:hover img {
            transform: scale(1.1);
        }

        .gallery-item .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            color: white;
            font-size: 2rem;
            pointer-events: none;
        }

        .gallery-item:hover .overlay {
            opacity: 1;
        }

        .gallery-item .caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            color: white;
            padding: 20px;
            transform: translateY(100%);
            transition: transform 0.5s;
            font-size: 1rem;
            text-align: center;
            font-weight: 500;
            pointer-events: none;
        }

        .gallery-item:hover .caption {
            transform: translateY(0);
        }

        /* ============ ENHANCED MODAL (LIGHTBOX) - ADJUSTED FOR PC ============ */
        .modal-content.bg-transparent {
            background: transparent !important;
        }

        .btn-close-white {
            filter: invert(1) grayscale(100%) brightness(200%);
            opacity: 0.8;
            position: absolute;
            right: 20px;
            top: 20px;
            z-index: 1060;
        }

        .lightbox-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 60vh;
        }

        .lightbox-img {
            max-width: 100%;
            max-height: 70vh;
            width: auto;
            height: auto;
            border-radius: 8px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        /* Make modal dialog smaller on large screens */
        @media (min-width: 992px) {
            .modal-dialog {
                max-width: 900px;
            }
        }

        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.3);
            border: none;
            color: white;
            font-size: 2.5rem;
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transition: background 0.3s;
            z-index: 1050;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .lightbox-nav:hover {
            background: rgba(255,255,255,0.6);
            color: #333;
        }

        .lightbox-nav.prev {
            left: 20px;
        }

        .lightbox-nav.next {
            right: 20px;
        }

        .lightbox-caption {
            position: absolute;
            bottom: 20px;
            left: 0;
            right: 0;
            text-align: center;
            color: white;
            font-size: 1.2rem;
            text-shadow: 0 2px 5px black;
            background: rgba(0,0,0,0.4);
            padding: 8px 20px;
            border-radius: 30px;
            width: fit-content;
            margin: 0 auto;
            backdrop-filter: blur(3px);
        }

        .lightbox-counter {
            position: absolute;
            top: 20px;
            left: 20px;
            color: white;
            background: rgba(0,0,0,0.5);
            padding: 5px 15px;
            border-radius: 30px;
            font-size: 1rem;
            backdrop-filter: blur(3px);
        }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-15px); }
            60% { transform: translateY(-7px); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .lightbox-nav {
                font-size: 1.8rem;
                padding: 5px 10px;
            }
        }

        /* Additional adjustment for PC: reduce navigation button size */
        @media (min-width: 992px) {
            .lightbox-nav {
                font-size: 2rem;
                padding: 8px 16px;
            }
        }
    </style>
</head>
