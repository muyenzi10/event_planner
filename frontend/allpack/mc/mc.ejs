<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Professional Master of Ceremony services for weddings and events. Book now for an unforgettable experience.">
    <meta name="keywords" content="wedding MC, event host, wedding planner, professional MC">
    <meta name="author" content="Wedding Planner">
    <title>Master of Ceremony</title>
    <!-- Bootstrap CSS -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
        crossorigin="anonymous"
    />
    <!-- Font Awesome for icons -->
    <link
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
        rel="stylesheet"
    />
    <!-- AOS Animation Library -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/allpack/layout/css/navbas.css">
    <link rel="stylesheet" href="/allpack/layout/css/footer.css">
    
    <style>
        /* Custom Styles */
        body {
            font-family: 'Montserrat', sans-serif;
        }

        /* ============ REDESIGNED HERO SECTION ============ */
        .mc-hero {
            position: relative;
            width: 100%;
            height: 90vh;
            min-height: 600px;
            background: url('/allpack/mc/mcdata/background.jpg') no-repeat center center/cover;
            background-attachment: fixed; /* subtle parallax */
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            overflow: hidden;
        }

        /* Overlay with gradient and noise texture */
        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.8) 100%);
            z-index: 1;
        }

        /* Floating elements for visual interest */
        .hero-float-icon {
            position: absolute;
            font-size: 3rem;
            color: rgba(255,255,255,0.15);
            z-index: 2;
            pointer-events: none;
        }

        .float-1 {
            top: 15%;
            left: 10%;
            animation: float 6s ease-in-out infinite;
        }
        .float-2 {
            bottom: 20%;
            right: 8%;
            font-size: 4rem;
            animation: float 8s ease-in-out infinite reverse;
        }
        .float-3 {
            top: 30%;
            right: 15%;
            font-size: 2.5rem;
            animation: float 5s ease-in-out infinite;
        }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }

        .hero-content {
            position: relative;
            z-index: 3;
            max-width: 900px;
            padding: 0 20px;
        }

        .hero-subtitle {
            font-family: 'Dancing Script', cursive;
            font-size: 2rem;
            margin-bottom: 1rem;
            opacity: 0.9;
            letter-spacing: 2px;
            animation: fadeInUp 1s ease-out;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3rem, 8vw, 5.5rem);
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 15px rgba(0,0,0,0.5);
            animation: fadeInUp 1s ease-out 0.2s both;
        }

        .hero-title span {
            color: #f7cac9; /* blush accent */
            display: inline-block;
            position: relative;
        }

        .hero-title span::after {
            content: '';
            position: absolute;
            bottom: 5px;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #f7cac9, transparent);
        }

        .hero-description {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 1s ease-out 0.4s both;
        }

        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            animation: fadeInUp 1s ease-out 0.6s both;
        }

        .btn-hero-primary {
            background: linear-gradient(135deg, #9b8bcf 0%, #b76e79 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(107, 91, 149, 0.4);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
        }

        .btn-hero-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(107, 91, 149, 0.6);
            color: white;
        }

        .btn-hero-secondary {
            background: transparent;
            border: 2px solid white;
            color: white;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
            backdrop-filter: blur(5px);
        }

        .btn-hero-secondary:hover {
            background: white;
            color: #333;
            border-color: white;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 3rem;
            }
            .hero-description {
                font-size: 1.1rem;
            }
            .btn-hero-primary, .btn-hero-secondary {
                padding: 0.8rem 1.8rem;
                font-size: 1rem;
            }
        }

        /* Content Section */
        .mc-content {
            padding: 80px 0;
        }

        .mc-content h2 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .mc-content .lead {
            font-size: 1.2rem;
            line-height: 1.8;
        }

        .mc-content ul {
            list-style: none;
            padding: 0;
        }

        .mc-content ul li {
            margin-bottom: 10px;
            font-size: 1.1rem;
        }

        .mc-content ul li i {
            margin-right: 10px;
            color: #28a745;
        }

        /* Carousel Section */
        #mcCarousel {
            height: 400px;
            overflow: hidden;
            border-radius: 10px;
        }

        .carousel-inner, .carousel-item {
            height: 100%;
        }

        .carousel-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 10px;
        }

        .carousel-control-prev,
        .carousel-control-next {
            width: 5%;
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            background-color: rgba(0, 0, 0, 0.5);
            border-radius: 50%;
            padding: 10px;
        }

        /* Testimonials Section */
        .mc-testimonials {
            background: #f8f9fa;
            padding: 80px 0;
        }

        .mc-testimonials h2 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 40px;
            text-align: center;
        }

        .testimonial-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .testimonial-card:hover {
            transform: translateY(-10px);
        }

        .testimonial-card p {
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .testimonial-card .text-end {
            font-weight: bold;
            color: #333;
        }

        /* Gallery Section */
        .mc-gallery {
            padding: 80px 0;
        }

        .mc-gallery h2 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 40px;
            text-align: center;
        }

        .mc-gallery img {
            border-radius: 10px;
            transition: transform 0.3s ease;
        }

        .mc-gallery img:hover {
            transform: scale(1.05);
        }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>
    <%- include('../layout/navbar') %>

    <!-- REDESIGNED MC HERO SECTION (without stats card) -->
    <section class="mc-hero" data-aos="fade-down">
        <div class="hero-overlay"></div>
        
        <!-- Floating decorative icons -->
        <div class="hero-float-icon float-1"><i class="fas fa-microphone-alt"></i></div>
        <div class="hero-float-icon float-2"><i class="fas fa-glass-cheers"></i></div>
        <div class="hero-float-icon float-3"><i class="fas fa-music"></i></div>

        <div class="hero-content text-center">
            <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="100">The Voice of Your Celebration</p>
            <h1 class="hero-title" data-aos="fade-up" data-aos-delay="200">
                Master of <span>Ceremony</span>
            </h1>
            <p class="hero-description" data-aos="fade-up" data-aos-delay="300">
                Make your wedding unforgettable with our professional MC services. 
                Charismatic, engaging, and tailored to your story.
            </p>
            <div class="hero-buttons" data-aos="fade-up" data-aos-delay="400">
                <a href="/booking" class="btn-hero-primary"><i class="fas fa-calendar-check"></i> Book Now</a>
                <a href="#gallery" class="btn-hero-secondary"><i class="fas fa-image"></i> images</a>
            </div>
        </div>
    </section>

    <!-- MC Content Section -->
    <section class="mc-content">
        <div class="container">
            <div class="row">
                <div class="col-md-6" data-aos="fade-right">
                    <!-- Image Slider -->
                    <div id="mcCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="/allpack/mc/mcdata/ran1.jpg" class="d-block w-100" alt="MC Image 1">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/Webp.net-resizeimage(14).jpg" class="d-block w-100" alt="MC Image 2">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/mc.jpg" class="d-block w-100" alt="MC Image 3">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/inganzo.jpg" class="d-block w-100" alt="MC Image 4">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/Webp.net-resizeimage(10).jpg" class="d-block w-100" alt="MC Image 5">
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#mcCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#mcCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
                <div class="col-md-6" data-aos="fade-left">
                    <h2>About Our MC</h2>
                    <p class="lead">Our Master of Ceremony is a seasoned professional with years of experience in hosting weddings and events. With a charismatic personality and excellent communication skills, they ensure your wedding runs smoothly and memorably.</p>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check-circle text-success"></i> Engaging and interactive hosting style</li>
                        <li><i class="fas fa-check-circle text-success"></i> Customized scripts tailored to your wedding theme</li>
                        <li><i class="fas fa-check-circle text-success"></i> Multilingual capabilities</li>
                        <li><i class="fas fa-check-circle text-success"></i> Professional audio equipment provided</li>
                    </ul>
                   
                </div>
            </div>
        </div>
    </section>

    <!-- MC Testimonials Section -->
    <section class="mc-testimonials">
        <div class="container">
            <h2 class="text-center mb-5" data-aos="fade-up">What Couples Say</h2>
            <div class="row">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="testimonial-card">
                        <p>"The MC was fantastic! They kept everyone entertained and made our wedding day truly special."</p>
                        <p class="text-end"><strong>- Sarah & John</strong></p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="testimonial-card">
                        <p>"We couldn't have asked for a better MC. They were professional, funny, and kept everything on schedule."</p>
                        <p class="text-end"><strong>- Emily & Michael</strong></p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="testimonial-card">
                        <p>"Our guests are still talking about how amazing the MC was. Highly recommend!"</p>
                        <p class="text-end"><strong>- Laura & David</strong></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MC Gallery Section -->
    <section class="mc-gallery" id="gallery">
        <div class="container">
            <h2 class="text-center mb-5" data-aos="fade-up">Gallery</h2>
            <div class="row">
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="100">
                    <img src="/allpack/mc/mcdata/ranf.webp" class="img-fluid rounded" alt="MC Image 1">
                </div>
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
                    <img src="/allpack/mc/mcdata/mc1.jpg" class="img-fluid rounded" alt="MC Image 2">
                </div>
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <img src="/allpack/mc/mcdata/muvunyi.jpg" class="img-fluid rounded" alt="MC Image 3">
                </div>
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <img src="/allpack/mc/mcdata/eric.jpeg" class="img-fluid rounded" alt="MC Image 3">
                </div>
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <img src="/allpack/mc/mcdata/igihame2.jpeg" class="img-fluid rounded" alt="MC Image 3">
                </div>
                <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <img src="/allpack/mc/mcdata/kamanzi.jpg" class="img-fluid rounded" alt="MC Image 3">
                </div>
            </div>
        </div>
    </section>


    <!-- MC FAQ Section -->
    <section class="mc-faq py-5">
        <div class="container">
            <h2 class="text-center mb-5" data-aos="fade-up">Frequently Asked Questions</h2>
            <div class="accordion" id="faqAccordion">
                <div class="accordion-item" data-aos="fade-up" data-aos-delay="100">
                    <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                            What is included in the MC service?
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Our MC service includes a customized script, professional hosting, and coordination with your event timeline.
                        </div>
                    </div>
                </div>
                <div class="accordion-item" data-aos="fade-up" data-aos-delay="200">
                    <h2 class="accordion-header" id="headingTwo">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                            Can the MC speak multiple languages?
                        </button>
                    </h2>
                    <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Yes, our MC is fluent in Kinyarwanda, English, and French.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <%- include('../layout/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script
        src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"
        integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p"
        crossorigin="anonymous"
    ></script>
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js"
        integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF"
        crossorigin="anonymous"
    ></script>
    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
        });
    </script>
</body>
</html>