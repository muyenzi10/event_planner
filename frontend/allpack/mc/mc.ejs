<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Professional Master of Ceremony services for weddings and events. Book now for an unforgettable experience.">
    <meta name="keywords" content="wedding MC, event host, wedding planner, professional MC">
    <meta name="author" content="Wedding Planner">
    <title>Master of Ceremony</title>
    <!-- Bootstrap CSS -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
        crossorigin="anonymous"
    />
    <!-- Font Awesome for icons -->
    <link
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
        rel="stylesheet"
    />
    <!-- AOS Animation Library -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/allpack/layout/css/navbas.css">
    <link rel="stylesheet" href="/allpack/layout/css/footer.css">
    
    <style>
        /* Custom Styles */
        body {
            font-family: 'Montserrat', sans-serif;
        }

        /* ============ REDESIGNED HERO SECTION ============ */
        .mc-hero {
            position: relative;
            width: 100%;
            height: 90vh;
            min-height: 600px;
            background: url('/allpack/mc/mcdata/background.jpg') no-repeat center center/cover;
            background-attachment: fixed; /* subtle parallax */
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            overflow: hidden;
        }

        /* Overlay with gradient and noise texture */
        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.8) 100%);
            z-index: 1;
        }

        /* Floating elements for visual interest */
        .hero-float-icon {
            position: absolute;
            font-size: 3rem;
            color: rgba(255,255,255,0.15);
            z-index: 2;
            pointer-events: none;
        }

        .float-1 {
            top: 15%;
            left: 10%;
            animation: float 6s ease-in-out infinite;
        }
        .float-2 {
            bottom: 20%;
            right: 8%;
            font-size: 4rem;
            animation: float 8s ease-in-out infinite reverse;
        }
        .float-3 {
            top: 30%;
            right: 15%;
            font-size: 2.5rem;
            animation: float 5s ease-in-out infinite;
        }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }

        .hero-content {
            position: relative;
            z-index: 3;
            max-width: 900px;
            padding: 0 20px;
        }

        .hero-subtitle {
            font-family: 'Dancing Script', cursive;
            font-size: 2rem;
            margin-bottom: 1rem;
            opacity: 0.9;
            letter-spacing: 2px;
            animation: fadeInUp 1s ease-out;
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3rem, 8vw, 5.5rem);
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 15px rgba(0,0,0,0.5);
            animation: fadeInUp 1s ease-out 0.2s both;
        }

        .hero-title span {
            color: #f7cac9; /* blush accent */
            display: inline-block;
            position: relative;
        }

        .hero-title span::after {
            content: '';
            position: absolute;
            bottom: 5px;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #f7cac9, transparent);
        }

        .hero-description {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 1s ease-out 0.4s both;
        }

        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            animation: fadeInUp 1s ease-out 0.6s both;
        }

        .btn-hero-primary {
            background: linear-gradient(135deg, #9b8bcf 0%, #b76e79 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(107, 91, 149, 0.4);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
        }

        .btn-hero-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(107, 91, 149, 0.6);
            color: white;
        }

        .btn-hero-secondary {
            background: transparent;
            border: 2px solid white;
            color: white;
            font-weight: 600;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
            backdrop-filter: blur(5px);
        }

        .btn-hero-secondary:hover {
            background: white;
            color: #333;
            border-color: white;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 3rem;
            }
            .hero-description {
                font-size: 1.1rem;
            }
            .btn-hero-primary, .btn-hero-secondary {
                padding: 0.8rem 1.8rem;
                font-size: 1rem;
            }
        }

        /* ========== IMPROVED MC CONTENT SECTION ========== */
        .mc-content {
            padding: 100px 0;
            background: linear-gradient(135deg, #fff9f9 0%, #fff 100%);
        }

        #mcCarousel {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            border: 5px solid white;
        }

        #mcCarousel .carousel-control-prev,
        #mcCarousel .carousel-control-next {
            width: 8%;
            opacity: 0.8;
        }

        #mcCarousel .carousel-control-prev-icon,
        #mcCarousel .carousel-control-next-icon {
            background-color: rgba(107, 91, 149, 0.7);
            border-radius: 50%;
            padding: 15px;
        }

        .mc-content-text {
            padding-left: 40px;
        }

        .mc-content-text h2 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 700;
            color: #6b5b95;
            margin-bottom: 10px;
            position: relative;
        }

        .mc-content-text h2::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, #9b8bcf, #b76e79);
            border-radius: 2px;
        }

        .mc-content-text .subhead {
            font-family: 'Dancing Script', cursive;
            font-size: 1.8rem;
            color: #b76e79;
            margin: 20px 0 15px;
        }

        .mc-content-text .lead {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #555;
            margin-bottom: 30px;
        }

        .feature-list {
            list-style: none;
            padding: 0;
            margin-bottom: 40px;
        }

        .feature-list li {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            font-size: 1.1rem;
        }

        .feature-list li i {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #9b8bcf 0%, #b76e79 100%);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.3rem;
            margin-right: 20px;
            box-shadow: 0 10px 15px rgba(155, 139, 207, 0.3);
        }

        .feature-list li span {
            color: #444;
            font-weight: 500;
        }

        .mc-signature {
            font-family: 'Dancing Script', cursive;
            font-size: 1.8rem;
            color: #6b5b95;
            margin-top: 20px;
        }

        .mc-signature i {
            color: #b76e79;
            font-size: 1.2rem;
            margin: 0 10px;
        }

        /* ========== FIXED MC GALLERY SECTION (no cropping) ========== */
        .mc-gallery {
            padding: 80px 0;
            background: #f8f9fa;
        }

        .mc-gallery h2 {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            color: #6b5b95;
            margin-bottom: 40px;
            text-align: center;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .gallery-item {
            position: relative;
            overflow: hidden;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            height: 280px; /* fixed height for grid uniformity */
            width: 100%;
            cursor: pointer;
            background-color: #e9ecef; /* light background for letterboxing */
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* show full image without cropping */
            transition: transform 0.5s ease;
        }

        .gallery-item:hover img {
            transform: scale(1.1);
        }

        .gallery-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .gallery-item:hover .gallery-overlay {
            opacity: 1;
        }

        .gallery-overlay i {
            color: white;
            font-size: 2.5rem;
            text-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }

        /* Mobile adjustment */
        @media (max-width: 768px) {
            .gallery-item {
                height: 220px;
            }
        }

        @media (max-width: 768px) {
            .mc-content-text {
                padding-left: 0;
                margin-top: 40px;
            }
        }

        /* Testimonials Section (unchanged) */
        .mc-testimonials {
            background: #f8f9fa;
            padding: 80px 0;
        }

        .mc-testimonials h2 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 40px;
            text-align: center;
        }

        .testimonial-card {
            background: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .testimonial-card:hover {
            transform: translateY(-10px);
        }

        .testimonial-card p {
            font-size: 1.1rem;
            line-height: 1.8;
        }

        .testimonial-card .text-end {
            font-weight: bold;
            color: #333;
        }

        /* FAQ Section (unchanged) */
        .mc-faq {
            background: #f8f9fa;
            padding: 80px 0;
        }

        .mc-faq h2 {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 40px;
            text-align: center;
        }

        /* ========== IMPROVED LIGHTBOX MODAL (elegant & smooth) ========== */
        .lightbox-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(8px);
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .lightbox-modal.show {
            display: flex;
            opacity: 1;
        }

        .lightbox-content {
            position: relative;
            max-width: 90%;
            max-height: 90%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-image {
            max-width: 100%;
            max-height: 85vh;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            transform: scale(0.95);
            transition: transform 0.3s ease, opacity 0.3s ease;
            opacity: 0;
        }

        .lightbox-modal.show .lightbox-image {
            transform: scale(1);
            opacity: 1;
        }

        /* Close button - modern circle */
        .lightbox-close {
            position: absolute;
            top: -50px;
            right: -10px;
            background: rgba(255,255,255,0.15);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            font-size: 2rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            backdrop-filter: blur(4px);
            z-index: 10000;
        }

        .lightbox-close:hover {
            background: rgba(255,255,255,0.3);
            border-color: rgba(255,255,255,0.6);
            transform: rotate(90deg);
            color: #fff;
        }

        /* Navigation arrows - circular with gradient */
        .lightbox-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.15);
            border: 2px solid rgba(255,255,255,0.2);
            color: white;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            font-size: 2.2rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
            z-index: 10000;
        }

        .lightbox-nav:hover {
            background: rgba(255,255,255,0.3);
            border-color: rgba(255,255,255,0.5);
            transform: translateY(-50%) scale(1.1);
        }

        .lightbox-prev {
            left: 20px;
        }

        .lightbox-next {
            right: 20px;
        }

        /* Image counter - minimal pill */
        .lightbox-counter {
            position: absolute;
            bottom: -40px;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            font-size: 0.95rem;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
            padding: 6px 18px;
            border-radius: 30px;
            letter-spacing: 0.5px;
            border: 1px solid rgba(255,255,255,0.2);
            font-weight: 400;
        }

        @media (max-width: 768px) {
            .lightbox-nav {
                width: 44px;
                height: 44px;
                font-size: 1.6rem;
            }
            .lightbox-prev {
                left: 10px;
            }
            .lightbox-next {
                right: 10px;
            }
            .lightbox-close {
                top: -45px;
                right: 0;
                width: 42px;
                height: 42px;
                font-size: 1.8rem;
            }
            .lightbox-counter {
                bottom: -35px;
                font-size: 0.85rem;
                padding: 4px 14px;
            }
        }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>
    <%- include('../layout/navbar') %>

    <!-- REDESIGNED MC HERO SECTION (unchanged) -->
    <section class="mc-hero" data-aos="fade-down">
        <div class="hero-overlay"></div>
        
        <!-- Floating decorative icons -->
        <div class="hero-float-icon float-1"><i class="fas fa-microphone-alt"></i></div>
        <div class="hero-float-icon float-2"><i class="fas fa-glass-cheers"></i></div>
        <div class="hero-float-icon float-3"><i class="fas fa-music"></i></div>

        <div class="hero-content text-center">
            <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="100">The Voice of Your Celebration</p>
            <h1 class="hero-title" data-aos="fade-up" data-aos-delay="200">
                Master of <span>Ceremony</span>
            </h1>
            <p class="hero-description" data-aos="fade-up" data-aos-delay="300">
                Make your wedding unforgettable with our professional MC services. 
                Charismatic, engaging, and tailored to your story.
            </p>
            <div class="hero-buttons" data-aos="fade-up" data-aos-delay="400">
                <a href="/booking" class="btn-hero-primary"><i class="fas fa-calendar-check"></i> Book Now</a>
                <a href="#gallery" class="btn-hero-secondary"><i class="fas fa-image"></i> images</a>
            </div>
        </div>
    </section>

    <!-- IMPROVED MC CONTENT SECTION -->
    <section class="mc-content">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6" data-aos="fade-right">
                    <!-- Image Slider with improved styling -->
                    <div id="mcCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="/allpack/mc/mcdata/ran1.jpg" class="d-block w-100" alt="MC Image 1">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/Webp.net-resizeimage(14).jpg" class="d-block w-100" alt="MC Image 2">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/mc.jpg" class="d-block w-100" alt="MC Image 3">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/inganzo.jpg" class="d-block w-100" alt="MC Image 4">
                            </div>
                            <div class="carousel-item">
                                <img src="/allpack/mc/mcdata/Webp.net-resizeimage(10).jpg" class="d-block w-100" alt="MC Image 5">
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#mcCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#mcCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
                <div class="col-md-6 mc-content-text" data-aos="fade-left">
                    <h2>About Our MC</h2>
                    <div class="subhead">Meet the voice behind the mic</div>
                    <p class="lead">Our Master of Ceremony is a seasoned professional with years of experience in hosting weddings and events. With a charismatic personality and excellent communication skills, they ensure your wedding runs smoothly and memorably.</p>
                    
                    <ul class="feature-list">
                        <li><i class="fas fa-microphone-alt"></i> <span>Engaging and interactive hosting style</span></li>
                        <li><i class="fas fa-heart"></i> <span>Customized scripts tailored to your theme</span></li>
                        <li><i class="fas fa-language"></i> <span>Fluent in Kinyarwanda, English & French</span></li>
                        <li><i class="fas fa-volume-up"></i> <span>Professional audio equipment included</span></li>
                    </ul>

                    <div class="mc-signature">
                        <i class="fas fa-quote-left"></i> Let's make your day unforgettable <i class="fas fa-quote-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MC Testimonials Section (unchanged) -->
    <section class="mc-testimonials">
        <div class="container">
            <h2 class="text-center mb-5" data-aos="fade-up">What Couples Say</h2>
            <div class="row">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="testimonial-card">
                        <p>"The MC was fantastic! They kept everyone entertained and made our wedding day truly special."</p>
                        <p class="text-end"><strong>- Sarah & John</strong></p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="testimonial-card">
                        <p>"We couldn't have asked for a better MC. They were professional, funny, and kept everything on schedule."</p>
                        <p class="text-end"><strong>- Emily & Michael</strong></p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="testimonial-card">
                        <p>"Our guests are still talking about how amazing the MC was. Highly recommend!"</p>
                        <p class="text-end"><strong>- Laura & David</strong></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FIXED MC GALLERY SECTION (no cropping) -->
    <section class="mc-gallery" id="gallery">
        <div class="container">
            <h2 data-aos="fade-up">Moments Captured</h2>
            <div class="gallery-grid">
                <div class="gallery-item" data-aos="zoom-in">
                    <img src="/allpack/mc/mcdata/ranf.webp" alt="MC Image 1">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="gallery-item" data-aos="zoom-in" data-aos-delay="100">
                    <img src="/allpack/mc/mcdata/mc1.jpg" alt="MC Image 2">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="gallery-item" data-aos="zoom-in" data-aos-delay="200">
                    <img src="/allpack/mc/mcdata/muvunyi.jpg" alt="MC Image 3">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="gallery-item" data-aos="zoom-in">
                    <img src="/allpack/mc/mcdata/eric.jpeg" alt="MC Image 4">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="gallery-item" data-aos="zoom-in" data-aos-delay="100">
                    <img src="/allpack/mc/mcdata/igihame2.jpeg" alt="MC Image 5">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
                <div class="gallery-item" data-aos="zoom-in" data-aos-delay="200">
                    <img src="/allpack/mc/mcdata/kamanzi.jpg" alt="MC Image 6">
                    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
                </div>
            </div>
        </div>
    </section>

    <!-- MC FAQ Section (unchanged) -->
    <section class="mc-faq py-5">
        <div class="container">
            <h2 class="text-center mb-5" data-aos="fade-up">Frequently Asked Questions</h2>
            <div class="accordion" id="faqAccordion">
                <div class="accordion-item" data-aos="fade-up" data-aos-delay="100">
                    <h2 class="accordion-header" id="headingOne">
