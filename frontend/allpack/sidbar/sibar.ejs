<!-- Hidden checkbox that controls the sidebar on mobile -->
<input type="checkbox" id="mobileMenuToggle" class="menu-checkbox">

<!-- Mobile toggle button (label) – this is what you click -->
<label for="mobileMenuToggle" class="mobile-toggle">
  <i class="fas fa-bars"></i> Menu
</label>

<!-- Sidebar navigation -->
<nav class="sidebar pinned" id="sidebar">
  <div class="sidebar-header">
    <h2>
      <i class="fas fa-heart"></i>
      <span>Wedding Planner</span>
    </h2>
    <!-- Desktop collapse button (still uses JavaScript) -->
    <button class="toggle-btn" id="toggleSidebar" title="Collapse sidebar">
      <i class="fas fa-bars"></i>
    </button>
  </div>

  <div class="nav-links">
    <!-- Your existing nav links with EJS active classes -->
    <a href="/home" class="nav-link <%= activeP === 'home' ? 'active' : '' %>">
      <i class="fas fa-home"></i> <span>Back Home</span>
    </a>
    <a href="/Dashboard/view/suppliers" class="nav-link <%= activeP === 'suppliersformat' ? 'active' : '' %>">
      <i class="fas fa-users"></i> <span>Suppliers</span>
    </a>
    <a href="/Dashboard/booking" class="nav-link <%= activeP === 'bookingformat' ? 'active' : '' %>">
      <i class="fas fa-bookmark"></i> <span>Bookings</span>
    </a>
    <a href="/dashboard/decor" class="nav-link <%= activeP === 'decorformat' ? 'active' : '' %>">
      <i class="fas fa-image"></i> <span>Decor</span>
    </a>
    <a href="/dashboard/troupe" class="nav-link <%= activeP === 'troupeformat' ? 'active' : '' %>">
      <i class="fas fa-drum"></i> <span>Troupe</span>
    </a>
    <a href="/dashboard/media" class="nav-link <%= activeP === 'mediaformat' ? 'active' : '' %>">
      <i class="fas fa-camera"></i> <span>Photo & Video</span>
    </a>
    <a href="/dashboard/catering" class="nav-link <%= activeP === 'cateringformat' ? 'active' : '' %>">
      <i class="fas fa-utensils me-2"></i> <span>Catering</span>
    </a>
    <a href="/dashboard/services" class="nav-link <%= activeP === 'irizadash' ? 'active' : '' %>">
      <i class="fas fa-concierge-bell me-2"></i> <span>Hospitality</span>
    </a>
    <a href="/dashboard/home" class="nav-link <%= activeP === 'homedash' ? 'active' : '' %>">
      <i class="fas fa-house me-2"></i> <span>Home</span>
    </a>
    <a href="/packages/dashboard" class="nav-link <%= activeP === 'servicepack' ? 'active' : '' %>">
      <i class="fas fa-box-open me-2"></i> <span>Services</span>
    </a>
    <a href="/direct/api/signup" class="nav-link <%= activeP === 'signupformat' ? 'active' : '' %>">
      <i class="fas fa-user-plus"></i> <span>Signup</span>
    </a>
  </div>

  <div class="sidebar-footer">
    &copy; 2025 Wedding Planner Pro
  </div>
</nav>

<!-- Overlay for mobile (clicking it closes the sidebar) -->
<label for="mobileMenuToggle" class="sidebar-overlay"></label>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const sidebar = document.getElementById("sidebar");
  const toggleBtn = document.getElementById("toggleSidebar");

  // Desktop collapse
  if (toggleBtn) {
    toggleBtn.addEventListener("click", function () {
      if (window.innerWidth > 768) {
        sidebar.classList.toggle("collapsed");
      }
    });
  }

  // Optional: When a nav link is clicked on mobile, uncheck the checkbox to close sidebar
  const navLinks = document.querySelectorAll(".nav-link");
  const menuCheckbox = document.getElementById("mobileMenuToggle");
  if (menuCheckbox) {
    navLinks.forEach(link => {
      link.addEventListener("click", function () {
        if (window.innerWidth <= 768) {
          menuCheckbox.checked = false; // uncheck to hide sidebar
        }
      });
    });
  }
});
</script>